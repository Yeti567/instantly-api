# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Your Instantly.ai V2 API key (create one in Instantly under Settings, Integrations, API).
# This must be a V2 key. V1 keys do not work with this server.
INSTANTLY_API_KEY=your_instantly_v2_api_key_here

# A long random secret that callers must present to use this MCP server.
# Generate one, for example: openssl rand -hex 32
# The MCP client sends it as: Authorization: Bearer <MCP_AUTH_TOKEN>
MCP_AUTH_TOKEN=replace_with_a_long_random_secret
